#!/usr/bin/env bash
set -euo pipefail

# Colors for high-visibility warnings/summaries.
if [[ -t 1 ]]; then
    color_yellow=$'\033[33m'
    color_red=$'\033[31m'
    color_bold=$'\033[1m'
    color_reset=$'\033[0m'
else
    color_yellow=''
    color_red=''
    color_bold=''
    color_reset=''
fi

declare -a install_warnings=()

warn() {
    local message=$1
    printf '%sWarning:%s %s\n' "$color_yellow" "$color_reset" "$message" >&2
    install_warnings+=("$message")
}

print_warning_summary() {
    if ((${#install_warnings[@]} == 0)); then
        return 0
    fi

    printf '\n%s%sTool setup completed with warnings:%s\n' "$color_red" "$color_bold" "$color_reset" >&2
    for warning in "${install_warnings[@]}"; do
        printf '%s  - %s%s\n' "$color_red" "$warning" "$color_reset" >&2
    done
}

load_homebrew() {
    if command -v brew >/dev/null 2>&1; then
        return 0
    fi

    if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    elif [[ -d "$HOME/.linuxbrew" ]]; then
        eval "$("$HOME/.linuxbrew/bin/brew" shellenv)"
    fi

    command -v brew >/dev/null 2>&1
}

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"
mkdir -p "$state_dir"

managed_formulas_file="$state_dir/homebrew-formulas.txt"
managed_casks_file="$state_dir/homebrew-casks.txt"
managed_uv_tools_file="$state_dir/uv-tools.txt"
managed_llm_plugins_file="$state_dir/llm-plugins.txt"

read_state_file() {
    local file_path=$1
    local array_name=$2
    local -n items_ref="$array_name"

    items_ref=()
    if [[ -f "$file_path" ]]; then
        mapfile -t items_ref < "$file_path"
    fi
}

write_state_file() {
    local file_path=$1
    shift

    if (($# > 0)); then
        printf '%s\n' "$@" > "$file_path"
    else
        : > "$file_path"
    fi
}

reconcile_brew_items() {
    local scope_flag=$1
    local label=$2
    local desired_array_name=$3
    local managed_file=$4
    local -n desired_items_ref="$desired_array_name"
    local -a installed_items=()
    local -a outdated_items=()
    local -a previously_managed_items=()
    local -a brew_scope_args=()
    declare -A desired_items_set=()
    declare -A installed_items_set=()
    declare -A outdated_items_set=()

    if [[ -n "$scope_flag" ]]; then
        brew_scope_args+=("$scope_flag")
    fi

    mapfile -t installed_items < <(brew list "${brew_scope_args[@]}")
    mapfile -t outdated_items < <(brew outdated --quiet "${brew_scope_args[@]}" || true)
    read_state_file "$managed_file" previously_managed_items

    for item in "${desired_items_ref[@]}"; do
        desired_items_set["$item"]=1
    done

    for item in "${installed_items[@]}"; do
        installed_items_set["$item"]=1
    done

    for item in "${outdated_items[@]}"; do
        outdated_items_set["$item"]=1
    done

    echo "Reconciling homebrew $label..."
    for item in "${desired_items_ref[@]}"; do
        if [[ -n "${installed_items_set[$item]+x}" ]]; then
            if [[ -n "${outdated_items_set[$item]+x}" ]]; then
                echo "Upgrading $label: $item"
                if ! brew upgrade "${brew_scope_args[@]}" "$item"; then
                    warn "Failed to upgrade $label '$item'"
                fi
            else
                echo "$label already up to date: $item"
            fi
        else
            echo "Installing $label: $item"
            if ! brew install "${brew_scope_args[@]}" "$item"; then
                warn "Failed to install $label '$item'"
            fi
        fi
    done

    for item in "${previously_managed_items[@]}"; do
        if [[ -z "${desired_items_set[$item]+x}" && -n "${installed_items_set[$item]+x}" ]]; then
            echo "Uninstalling removed $label: $item"
            if ! brew uninstall "${brew_scope_args[@]}" "$item"; then
                warn "Failed to uninstall removed $label '$item'"
            fi
        fi
    done

    write_state_file "$managed_file" "${desired_items_ref[@]}"
}

list_uv_tools() {
    uv tool list | awk '/^[^-[:space:]]/ { print $1 }'
}

list_outdated_uv_tools() {
    uv tool list --outdated | awk '/^[^-[:space:]]/ { print $1 }'
}

reconcile_uv_tools() {
    local desired_array_name=$1
    local managed_file=$2
    local -n desired_items_ref="$desired_array_name"
    local -a installed_items=()
    local -a outdated_items=()
    local -a previously_managed_items=()
    declare -A desired_items_set=()
    declare -A installed_items_set=()
    declare -A outdated_items_set=()

    mapfile -t installed_items < <(list_uv_tools)
    mapfile -t outdated_items < <(list_outdated_uv_tools || true)
    read_state_file "$managed_file" previously_managed_items

    for item in "${desired_items_ref[@]}"; do
        desired_items_set["$item"]=1
    done

    for item in "${installed_items[@]}"; do
        installed_items_set["$item"]=1
    done

    for item in "${outdated_items[@]}"; do
        outdated_items_set["$item"]=1
    done

    echo "Reconciling uv tools..."
    for item in "${desired_items_ref[@]}"; do
        if [[ -n "${installed_items_set[$item]+x}" ]]; then
            if [[ -n "${outdated_items_set[$item]+x}" ]]; then
                echo "Upgrading uv tool: $item"
                if ! uv tool upgrade "$item"; then
                    warn "Failed to upgrade uv tool '$item'"
                fi
            else
                echo "uv tool already up to date: $item"
            fi
        else
            echo "Installing uv tool: $item"
            if ! uv tool install "$item"; then
                warn "Failed to install uv tool '$item'"
            fi
        fi
    done

    for item in "${previously_managed_items[@]}"; do
        if [[ -z "${desired_items_set[$item]+x}" && -n "${installed_items_set[$item]+x}" ]]; then
            echo "Uninstalling removed uv tool: $item"
            if ! uv tool uninstall "$item"; then
                warn "Failed to uninstall removed uv tool '$item'"
            fi
        fi
    done

    write_state_file "$managed_file" "${desired_items_ref[@]}"
}

list_llm_plugins() {
    llm plugins | sed -n 's/^[[:space:]]*"name": "\([^"]*\)",$/\1/p'
}

reconcile_llm_plugins() {
    local desired_array_name=$1
    local managed_file=$2
    local -n desired_items_ref="$desired_array_name"
    local -a installed_items=()
    local -a previously_managed_items=()
    declare -A desired_items_set=()
    declare -A installed_items_set=()

    mapfile -t installed_items < <(list_llm_plugins)
    read_state_file "$managed_file" previously_managed_items

    for item in "${desired_items_ref[@]}"; do
        desired_items_set["$item"]=1
    done

    for item in "${installed_items[@]}"; do
        installed_items_set["$item"]=1
    done

    echo "Reconciling llm plugins..."
    for item in "${desired_items_ref[@]}"; do
        if [[ -n "${installed_items_set[$item]+x}" ]]; then
            echo "llm plugin already installed: $item"
        else
            echo "Installing llm plugin: $item"
            if ! llm install "$item"; then
                warn "Failed to install llm plugin '$item'"
            fi
        fi
    done

    for item in "${previously_managed_items[@]}"; do
        if [[ -z "${desired_items_set[$item]+x}" && -n "${installed_items_set[$item]+x}" ]]; then
            echo "Uninstalling removed llm plugin: $item"
            if ! llm uninstall -y "$item"; then
                warn "Failed to uninstall removed llm plugin '$item'"
            fi
        fi
    done

    write_state_file "$managed_file" "${desired_items_ref[@]}"
}

desired_formulas=(
{{- range .homebrew.formulas.core }}
    "{{ . }}"
{{- end }}
{{- if not .is_mobile }}
{{- range .homebrew.formulas.desktop }}
    "{{ . }}"
{{- end }}
{{- end }}
)

desired_casks=(
{{- if not .is_mobile }}
{{- range .homebrew.casks.desktop }}
    "{{ . }}"
{{- end }}
{{- end }}
)

desired_uv_tools=(
{{- range .uv.tools }}
    "{{ . }}"
{{- end }}
)

desired_llm_plugins=(
{{- range .llm.plugins }}
    "{{ . }}"
{{- end }}
)

if load_homebrew; then
    reconcile_brew_items "--formula" "formula" desired_formulas "$managed_formulas_file"
    reconcile_brew_items "--cask" "cask" desired_casks "$managed_casks_file"
else
    warn "Homebrew not found, skipping homebrew package reconciliation"
fi

if ! command -v uv >/dev/null 2>&1; then
    warn "uv not found, skipping uv tool reconciliation"
else
    reconcile_uv_tools desired_uv_tools "$managed_uv_tools_file"
fi

{{- if .llm.plugins }}
if command -v llm >/dev/null 2>&1; then
    reconcile_llm_plugins desired_llm_plugins "$managed_llm_plugins_file"
else
    warn "llm not found, skipping llm plugin reconciliation"
fi
{{- end }}

# Install nvm
nvm_dir="${XDG_DATA_HOME:-$HOME/.local/share}/nvm"
if [[ ! -s "$nvm_dir/nvm.sh" ]]; then
    if ! PROFILE=/dev/null curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash; then
        warn "Failed to install nvm"
    fi
fi

echo "Tool installation completed."
print_warning_summary
