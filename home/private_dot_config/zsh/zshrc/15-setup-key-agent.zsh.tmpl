# Warn if any GPG key or subkey expires within 30 days
if command -v gpg >/dev/null 2>&1; then
  gpg --list-keys --with-colons 2>/dev/null | awk -F: '
    /^[ps]ub:/ {
      key = $5
      expires_at = $7
      if (expires_at != "" && expires_at < systime() + 2592000) {
        print "\033[1;33mWarning: GPG key " key " expires within 30 days!\033[0m"
      }
    }'
fi

# Reuse one ssh-agent across shells and preload the Git signing key.
if command -v keychain >/dev/null 2>&1; then
  KEY_PATH="$HOME/.ssh/{{- .git_signing_key }}"
  KEYCHAIN_DIR="${XDG_RUNTIME_DIR:-$XDG_CACHE_HOME}/keychain"

  if [[ -f "$KEY_PATH" ]]; then
    eval "$(keychain --eval --quiet --absolute --dir "$KEYCHAIN_DIR" "$KEY_PATH")"
  else
    eval "$(keychain --eval --quiet --absolute --dir "$KEYCHAIN_DIR")"
  fi

  unset KEY_PATH
  unset KEYCHAIN_DIR
fi

# GPG agent setup for pass and GPG operations
if tty -s && command -v gpg-connect-agent >/dev/null 2>&1; then
  GPG_TTY=$(tty)
  export GPG_TTY
  gpg-connect-agent updatestartuptty /bye >/dev/null
fi
