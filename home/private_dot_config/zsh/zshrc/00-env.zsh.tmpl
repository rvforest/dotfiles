
# 00-env.zsh — general environment variables (non-PATH)

# XDG Base Directories
export XDG_DATA_HOME="{{ .xdg.data_home }}"
export XDG_CONFIG_HOME="{{ .xdg.config_home }}"
export XDG_CACHE_HOME="{{ .xdg.cache_home }}"
export XDG_STATE_HOME="{{ .xdg.state_home }}"

# oh-my-zsh install location
export ZSH="$XDG_CONFIG_HOME/zsh/oh-my-zsh"

# ZSH env vars
export ZSH="$XDG_DATA_HOME/oh-my-zsh"
export ZSH_COMPDUMP="$XDG_CACHE_HOME/zsh/.zcompdump"

# Locale and Editor
export LANG=en_US.UTF-8
export EDITOR='nvim'

# Config files
export GIT_CONFIG_GLOBAL="$XDG_CONFIG_HOME/git/config"
export WGETRC="$XDG_CONFIG_HOME/wget/wgetrc"

export HISTFILE="$XDG_STATE_HOME/zsh_history"
export PYTHONHISTFILE="$XDG_STATE_HOME/python_history"
export LESSHISTFILE="$XDG_STATE_HOME/lesshst"
export TS_NODE_REPL_HISTORY="$XDG_STATE_HOME/ts_node_repl_history"
export NODE_REPL_HISTORY="$XDG_STATE_HOME/node_repl_history"

# Toolchain data
export RUSTUP_HOME="$XDG_DATA_HOME/rustup"
export CARGO_HOME="$XDG_DATA_HOME/cargo"
# GnuPG keyring and config
export GNUPGHOME="$XDG_DATA_HOME/gnupg"

# npm XDG compliance
export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"
export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
# For global installs (optional, set in npmrc):
# prefix=$XDG_DATA_HOME/npm

# pass XDG compliance
export PASSWORD_STORE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/pass"

# llm
export LLM_MODEL="openrouter/meta-llama/llama-4-scout"

# nvm XDG compliance
export NVM_DIR="$XDG_DATA_HOME/nvm"

# Load NVM without letting its installer edit this managed zshrc.
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
	. "$NVM_DIR/nvm.sh"
fi
