# ohmyzsh.zsh - Oh My Zsh theme and plugin settings
export ZSH="$HOME/.oh-my-zsh"

plugins=(
  aliases  # show/search aliases
  eza  # eza aliases
  fzf  # enable fzf integration
  gh  # GitHub CLI completions
  git  # git aliases
  git-auto-fetch  # automatically fetch
  git-extras  # Extra completions
  mise
  pre-commit  # pre-commit aliases
  vscode  # aliases to open VSCode
  zoxide  # iniate zoxide integration
  zsh-vi-mode  # vim mode
)
plugins+=zsh-syntax-highlighting

zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 13

source $ZSH/oh-my-zsh.sh
