{{/* boolean feature tags */}}
{{- $is_ephemeral := false -}}{{/* true if this machine is ephemeral, e.g. a cloud or VM instance */}}
{{- $is_headless := false -}}{{/* true if this machine does not have a screen and keyboard */}}
{{- $is_mobile := false -}}{{/* true if this machine is a mobile device */}}
{{- "" -}}

{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{/* detect mobile device */}}
{{- if eq .chezmoi.username "userland" -}}
{{-   $is_mobile = true -}}
{{- end -}}

{{/* detect GitHub codespaces, VSCode remote containers, Docker containers, Multipass VMs, and Vagrant boxes */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") -}}
{{-   $is_ephemeral = true -}}
{{-   $is_headless = true -}}
{{- else if $is_mobile -}}
{{-   $is_ephemeral = false -}}
{{-   $is_headless = true -}}
{{- end -}}

{{/* work around unreliable hostname on darwin */}}
{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname := output "scutil" "--get" "LocalHostName" | trim -}}
{{- end -}}

{{/* detect WSL */}}
{{- $is_wsl := false -}}
{{- $kernel := output "uname" "-r" | trim -}}
{{-   $kernelLower := lower $kernel -}}
{{-   if or ($kernelLower | contains "wsl") ($kernelLower | contains "microsoft") -}}
{{-     $is_wsl = true -}}
{{-   end -}}


[data]
    name = "Robert Forest"
    email = "rvforest@gmail.com"
    gh_user = "rvforest"
    is_ephemeral = {{ $is_ephemeral }}
    is_headless = {{ $is_headless }}
    is_mobile = {{ $is_mobile }}
    is_wsl = {{ $is_wsl }}
    hostname = {{ $hostname | quote }}

    git_signing_key = "id_git_signing"
    git_signing_key_comment = "git signing key"

    zshPlugins = [
        "aliases",  # show/search aliases
        "eza",  # eza aliases
        "direnv",  # direnv integration
        "gh",  # GitHub CLI completions
        "git",  # git aliases
        "git-auto-fetch",  # automatically fetch
        "git-extras",  # Extra completions
        "pre-commit",  # pre-commit aliases
        "vscode",  # aliases to open VSCode
        "zsh-vi-mode",  # vim mode
        "zsh-syntax-highlighting",
{{ if not $is_mobile -}}
        "fzf",
        "zoxide",  # initiate zoxide integration
{{ end -}}
    ]

[github]
    refreshPeriod = "12h"
